#!/bin/bash
set -euo pipefail

set -a
source /etc/gastitos-backup.env
set +a

TIMESTAMP=$(date +%Y-%m-%d_%H%M)
DUMP_FILE="gastitos-${TIMESTAMP}.sqlite3"

trap 'rm -f "/tmp/${DUMP_FILE}"' EXIT

echo "[$(date)] Starting backup..."

CONTAINER=$(docker ps --filter label=service=gastitos --filter label=role=web --format "{{.Names}}" | head -1)

docker exec "$CONTAINER" sqlite3 /rails/storage/production.sqlite3 ".backup '/tmp/backup.sqlite3'"
docker cp "$CONTAINER:/tmp/backup.sqlite3" "/tmp/${DUMP_FILE}"
docker exec "$CONTAINER" rm /tmp/backup.sqlite3

aws s3 cp "/tmp/${DUMP_FILE}" "s3://${B2_BUCKET}/gastitos/daily/${DUMP_FILE}"

echo "[$(date)] Backup complete: ${DUMP_FILE}"
