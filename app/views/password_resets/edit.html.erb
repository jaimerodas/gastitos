<main id="login">
  <div class="login-logo"><%= render "shared/logo" %></div>
  <h1><%= t("password_resets.edit.title") %></h1>

  <%= form_with model: @user, url: password_reset_path(token: params[:token]), method: :patch do |f| %>
    <% if @user.errors.any? %>
      <section role="alert">
        <h2><%= t("password_resets.edit.errors_title") %></h2>
        <ul>
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </section>
    <% end %>

    <div class="field">
      <%= f.label :password %>
      <%= f.password_field :password, required: true, autofocus: true %>
    </div>

    <div class="field">
      <%= f.label :password_confirmation %>
      <%= f.password_field :password_confirmation, required: true %>
    </div>

    <%= f.submit t("password_resets.edit.submit") %>
  <% end %>
</main>
