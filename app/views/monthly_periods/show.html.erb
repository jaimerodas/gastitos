<main class="double-column">
  <h1><%= @period.display_name %></h1>

  <%= render "transactions/form", transaction: @transaction, categories: @categories,
      period: @period %>

  <section id="monthly-summary">
    <h2><%= t("monthly_periods.show.pnl_title") %></h2>
    <table>
      <tbody>
        <tr>
          <td><a href="<%= edit_monthly_period_path(@period) %>"><%= t("monthly_periods.show.starting_balance") %></a></td>
          <td class="money"><%= number_to_currency(@period.starting_balance) %></td>
        </tr>

        <% if @income_by_category.any? %>
          <tr>
            <th class="section" colspan="2"><%= t("monthly_periods.show.income_section") %></th>
          </tr>
          <% @income_by_category.each do |name, total| %>
            <tr>
              <td><%= name %></td>
              <td class="money"><%= number_to_currency(total) %></td>
              <td></td>
            </tr>
          <% end %>
          <tr>
            <td><strong><%= t("monthly_periods.show.total_income") %></strong></td>
            <td class="money"><strong><%= number_to_currency(@period.total_income) %></strong></td>
            <td></td>
          </tr>
        <% end %>

        <% if @expenses_by_category.any? %>
          <tr>
            <th class="section" colspan="2"><%= t("monthly_periods.show.expenses_section") %></th>
          </tr>
          <% @expenses_by_category.each do |name, total| %>
            <tr>
              <td><%= name %></td>
              <td class="money"><%= number_to_currency(total.abs) %></td>
              <td></td>
            </tr>
          <% end %>
          <tr>
            <td><strong><%= t("monthly_periods.show.total_expenses") %></strong></td>
            <td class="money"><strong><%= number_to_currency(@period.total_expenses.abs) %></strong></td>
            <td></td>
          </tr>
        <% end %>
        <tr><td colspan="2">&nbsp;</td></tr>
        <tr>
          <td><strong><%= t("monthly_periods.show.net_income") %></strong></td>
          <td class="money"><strong><%= number_to_currency(@period.net_income) %></strong></td>
          <td></td>
        </tr>
        <tr>
          <td><strong><%= t("monthly_periods.show.ending_balance") %></strong></td>
          <td class="money"><strong><%= number_to_currency(@period.ending_balance) %></strong></td>
          <td></td>
        </tr>
      </tbody>
    </table>
  </section>

  <% if @transactions.any? %>
    <section id="transactions">
      <h2><%= @transactions.count %> <%= t("monthly_periods.show.transactions_title") %></h2>
      <table>
        <tbody>
          <% @transactions.group_by {|t| t.date.day }.each do |day, txns| %>
            <tr>
              <th class="section" colspan="2"><%= day %></th>
            </tr>
            <% txns.each do |txn| %>
            <tr>
              <td>
                <a href="<%= edit_transaction_path(txn, return_to: monthly_period_path(@period)) %>">
                  <%= txn.category.name %><% if txn.description.present? %>: <%= txn.description %><% end %>
                </a>
              </td>
              <td class="money"><%= number_to_currency(txn.amount) %></td>
            </tr>
            <% end %>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
</main>
