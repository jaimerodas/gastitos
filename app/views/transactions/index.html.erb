<main>
  <h1><%= t("transactions.index.title") %></h1>

  <% if current_user.can_edit? %>
    <%= render "form", transaction: @transaction, categories: @dashboard.categories %>
  <% end %>

  <% if @dashboard.stats.any? %>
    <section id="stats">
      <h2><%= t("transactions.index.stats_title") %></h2>
      <dl class="stats">
        <div>
          <dt><%= t("transactions.index.average_monthly") %></dt>
          <dd class="big"><%= number_to_currency(@dashboard.stats.average_monthly_spend) %></dd>
        </div>

        <div>
          <dt><%= t("transactions.index.total_spend") %></dt>
          <dd class="big"><%= number_to_currency(@dashboard.stats.total_spend) %></dd>
        </div>

        <% if @dashboard.stats.top_categories.any? %>
        <div>
          <dt><%= t("transactions.index.top_categories") %></dt>
          <dd>
            <ol>
              <% @dashboard.stats.top_categories.each do |cat| %>
                <li><%= cat[:name] %>: <%= number_to_currency(cat[:total]) %></li>
              <% end %>
            </ol>
          </dd>
        </div>
        <% end %>
      </dl>
    </section>
  <% end %>

  <section id="transactions">
    <h2><%= t("transactions.index.recent") %></h2>
    <% if @dashboard.recent_transactions.any? %>
      <table>
        <thead>
          <tr>
            <th width="110"><%= Transaction.human_attribute_name(:date) %></th>
            <th><%= Transaction.human_attribute_name(:category) %></th>
            <th class="money"><%= Transaction.human_attribute_name(:amount) %></th>
          </tr>
        </thead>
        <tbody>
          <% @dashboard.recent_transactions.each do |txn| %>
            <tr>
              <td class="tabular"><% period = @dashboard.period_for(txn) %><% if period %><a href="<%= monthly_period_path(period) %>"><%= txn.date.strftime("%Y-%m") %></a>-<%= "%02d" % txn.date.day %><% else %><%= txn.date.strftime("%Y-%m-%d") %><% end %></td>
              <td>
                <% if current_user.can_edit? %>
                  <a href="<%= edit_transaction_path(txn) %>">
                    <%= txn.category.name %><% if txn.description.present? %>: <%= txn.description %><% end %>
                  </a>
                <% else %>
                  <%= txn.category.name %><% if txn.description.present? %>: <%= txn.description %><% end %>
                <% end %>
              </td>
              <td class="money <%= txn.amount.negative? ? "amount-expense" : "amount-income" %>"><%= number_to_currency(txn.amount) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="empty-state"><%= t("transactions.index.empty_state") %></p>
    <% end %>
  </section>
</main>
