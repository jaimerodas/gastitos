<main id="user">
  <h1><%= @user.name %></h1>
  <span><%= @user.email %></span>

  <dl class="stats">
    <div>
      <dt><%= t("users.admin.status") %></dt>
      <dd><%= @user.approved? ? t("users.admin.approved_status") : t("users.admin.pending_status") %></dd>
    </div>

    <div>
      <dt><%= t("users.admin.permissions") %></dt>
      <dd><%= t("users.admin.#{@user.role}_role") %></dd>
    </div>

    <div>
      <dt><%= t("users.admin.created_at") %></dt>
      <dd><%= l(@user.created_at.to_date) %></dd>
    </div>
  </dl>

  <% if @user != current_user %>
    <section class="actions inline-actions">
      <% if @user.approved? %>
        <%= button_to t("users.admin.unapprove_button"), user_approval_path(@user), method: :delete %>
      <% else %>
        <%= button_to t("users.admin.approve_button"), user_approval_path(@user), method: :post %>
        <%= button_to t("users.admin.delete_button"), user_path(@user), method: :delete, data: { turbo_confirm: t("users.admin.confirm_delete") } %>
      <% end %>

      <% User.roles.each_key do |role| %>
        <% next if role == @user.role %>
        <%= button_to t("users.admin.make_role", role: t("users.admin.#{role}_role").downcase), user_role_path(@user), method: :patch, params: { role: role } %>
      <% end %>
    </section>
  <% end %>

  <section id="activity">
    <h2><%= t("users.admin.activity_title") %></h2>
    <% if @activity_lines.any? %>
      <pre><%= @activity_lines.join("\n") %></pre>
      <p><%= link_to t("users.admin.download_log"), activity_log_user_path(@user) %></p>
    <% else %>
      <p><%= t("users.admin.no_activity") %></p>
    <% end %>
  </section>

  <p><%= link_to t("users.admin.back"), users_path %></p>
</main>
